# Anthropic API key — used by the local Hono agent server (server/index.ts)
# Never use the VITE_ prefix here — these are server-only and never bundled into JS.
ANTHROPIC_KEY=sk-ant-api03-...

# Resend API key — used by /api/email/send-review to send transactional emails.
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Copy this file to .env and fill in your keys:
#   cp .env.example .env
